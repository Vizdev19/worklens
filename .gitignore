# Python
__pycache__/
*.pyc
*.pyo
# Match any virtualenv directory — bare names and per-version variants
# like venv-py312 (so when you spin up a fresh interpreter for a single
# script run, the few-thousand-file site-packages tree doesn't show up
# as "3000+ untracked files" in your IDE).
.venv/
venv/
venv-*/
*.egg-info/
.pytest_cache/

# Node
node_modules/
.next/

# Env
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
*.spec
# … but keep our hand-crafted PyInstaller spec
!agent/EmployeeMonitor.spec

# Agent runtime
queue.db

# OS
.DS_Store
Thumbs.db

# Vercel
.vercel
.env*.local
