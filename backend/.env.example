# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=screenshots

# PostgreSQL — use Supabase pooler URL (port 6543) for production
# Direct connection (port 5432) is fine for local dev
# IMPORTANT: URL-encode special chars in password (e.g., @ → %40)
# Driver MUST be postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT — generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS — comma-separated list of dashboard URLs
ALLOWED_ORIGINS=http://localhost:3000

# App
APP_NAME=EmployeeMonitor
ENVIRONMENT=development
