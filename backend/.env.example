# ── Supabase project credentials ─────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key       # service_role (secret) — never expose
SUPABASE_BUCKET=screenshots

# Supabase Auth JWT Secret — Project Settings → API → JWT Secret
# Used by the backend to validate tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=your-jwt-secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Use Supabase pooler URL (port 6543) in production to avoid exhausting connections.
# Direct connection (port 5432) is fine for local dev.
# IMPORTANT: URL-encode special chars in password (e.g. @ → %40).
# Driver MUST be postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=EmployeeMonitor
ENVIRONMENT=development
