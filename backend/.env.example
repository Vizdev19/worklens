# ── Supabase project credentials ─────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key       # service_role (secret) — never expose
SUPABASE_BUCKET=screenshots

# Supabase Auth JWT Secret — Project Settings → API → JWT Secret
# Used by the backend to validate tokens issued by Supabase Auth.
SUPABASE_JWT_SECRET=your-jwt-secret

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Use Supabase pooler URL (port 6543) in production to avoid exhausting connections.
# Direct connection (port 5432) is fine for local dev.
# IMPORTANT: URL-encode special chars in password (e.g. @ → %40).
# Driver MUST be postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=EmployeeMonitor
ENVIRONMENT=development

# Dashboard URL — origin of the app that owns /auth/callback. Supabase
# verification emails redirect here after the user clicks the link.
#
# IMPORTANT: this is the **dashboard** URL (the app users sign into),
# NOT the marketing site URL. The marketing site has no /auth/callback
# route. Setting this to the marketing domain breaks every signup flow.
#
# Examples:
#   Dev:  http://localhost:3000           (dashboard runs on port 3000)
#   Prod: https://app.employeemonitor.com
#
# Must also be listed in:
#   Supabase Dashboard → Auth → URL Configuration → Allowed Redirect URLs
#
# Legacy: FRONTEND_URL is still accepted as an alias for DASHBOARD_URL
# (kept so existing Vercel deployments don't break on this rename).
# New deployments should use DASHBOARD_URL.
DASHBOARD_URL=http://localhost:3000

# CORS — include both the marketing site and the dashboard app.
# Comma-separated; no trailing slashes.
# ALLOWED_ORIGINS=https://employeemonitor.com,https://app.employeemonitor.com

# ── Agent release pipeline ──────────────────────────────────────────────────
# Shared secret used by the CI release workflow to publish new agent
# manifests via POST /agent/version. Generate once with:
#     python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must match the AGENT_RELEASE_KEY GitHub Actions secret.
# Leave unset locally — POST /agent/version is disabled when this is empty.
AGENT_RELEASE_KEY=
